{
	"name": "devenv",
	"displayName": "devenv",
	"description": "Declarative developer environments for Visual Studio Code",
	"version": "0.6.0",
	"preview": true,
	"icon": "assets/icon.png",
	"maintainers": [
		{
			"name": "The devenv VSCode extension team",
			"url": "https://github.com/orgs/cachix/teams/vscode"
		}
	],
	"contributors": [
		{
			"name": "cab404",
			"url": "https://github.com/cab404"
		},
		{
			"name": "mkhl",
			"url": "https://github.com/mkhl"
		}
	],
	"publisher": "datakurre",
	"license": "0BSD",
	"repository": {
		"type": "git",
		"url": "https://github.com/datakurre/devenv-vscode"
	},
	"engines": {
		"vscode": "^1.71.0"
	},
	"categories": [
		"Other"
	],
	"activationEvents": [
		"*",
		"onLanguage"
	],
	"capabilities": {
		"untrustedWorkspaces": {
			"supported": false,
			"description": "devenv can run arbitrary shell code"
		}
	},
	"contributes": {
		"configuration": {
			"title": "devenv",
			"properties": {
				"devenv.extraEnv": {
					"type": "object",
					"scope": "machine-overridable",
					"description": "Environment variables that will be set before running devenv",
					"additionalProperties": {
						"type": "string"
					}
				},
				"devenv.extraArgs": {
					"type": "array",
					"items": {
						"type": "string"
					},
					"default": [],
					"scope": "resource",
					"description": "Additional arguments prepended to every devenv invocation. Each element is a separate argument. Shell environment variables and values from a .env file in the workspace root are interpolated (e.g. \"$NETRC\" or \"${NETRC}\"). Example: [\"--nix-option\", \"extra-sandbox-paths\", \"$NETRC\"]"
				},
				"devenv.watchForChanges": {
					"type": "boolean",
					"default": true,
					"description": "Automatically reload environment on file changes"
				},
				"devenv.profile": {
					"type": [
						"string",
						"null"
					],
					"default": null,
					"scope": "resource",
					"description": "devenv profile to use when loading the environment (e.g. 'shell'). When null (default), the profile is auto-detected from devenv.yaml / devenv.local.yaml. Set explicitly to override the detected value."
				},
				"devenv.path.executable": {
					"type": "string",
					"default": "devenv",
					"scope": "machine-overridable",
					"description": "Path to the devenv executable. Use an absolute path (e.g. /nix/var/nix/profiles/default/bin/devenv) if devenv is not found automatically."
				},
				"devenv.path.nixBinPaths": {
					"type": "array",
					"items": {
						"type": "string"
					},
					"default": [],
					"scope": "machine-overridable",
					"description": "Additional directories to prepend to PATH when running devenv. The extension already prepends the standard Nix profile directories and common system paths automatically; use this setting only when your installation is in a non-standard location."
				},
				"devenv.status.showChangesCount": {
					"type": "boolean",
					"default": true,
					"description": "Show the number of changed environment variables"
				},
				"devenv.restart.automatic": {
					"type": "boolean",
					"default": false,
					"description": "Automatically restart extension host upon environment changes"
				}
			}
		},
		"commands": [
			{
				"command": "devenv.open",
				"title": "devenv: Open devenv.nix file"
			},
			{
				"command": "devenv.reload",
				"title": "devenv: Reload environment"
			},
			{
				"command": "devenv.reset",
				"title": "devenv: Reset and reload environment"
			}
		],
		"menus": {
			"commandPalette": [
				{
					"command": "devenv.open"
				},
				{
					"command": "devenv.reload"
				},
				{
					"command": "devenv.reset"
				}
			],
			"explorer/context": [
				{
					"when": "resourceFilename == devenv.nix",
					"command": "devenv.open",
					"group": "5_devenv@1"
				}
			]
		}
	},
	"main": "./dist/extension.js",
	"scripts": {
		"version": "bin/update-changelog $npm_package_version && git add CHANGELOG.md",
		"package": "vsce package --allow-star-activation",
		"vscode:prepublish": "run-s \"build -- --minify {@}\" --",
		"clean": "rimraf ./out ./dist",
		"build": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --platform=node --target=node16 --external:vscode",
		"eslint": "eslint --cache --cache-location ./.cache/eslint/ .",
		"prettier": "prettier --cache --cache-location ./.cache/prettier/ .",
		"compile:source": "run-s \"build -- --sourcemap {@}\" --",
		"compile:tests": "tsc",
		"watch:source": "run-s \"compile:source -- --watch {@}\" --",
		"watch:tests": "run-s \"compile:tests -- --watch {@}\" --",
		"lint": "run-p --aggregate-output --continue-on-error lint:*",
		"lint:eslint": "run-s \"eslint -- {@}\" --",
		"lint:prettier": "run-s \"prettier -- --check {@}\" --",
		"fix": "run-p --aggregate-output --continue-on-error fix:*",
		"fix:eslint": "run-s \"eslint -- --fix {@}\" --",
		"fix:prettier": "run-s \"prettier -- --write {@}\" --",
		"pretest": "run-p --aggregate-output --continue-on-error compile:*",
		"test": "node ./out/test/runTest.js"
	},
	"overrides": {
		"serialize-javascript": "^7.0.4",
		"diff": "^8.0.3"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/mocha": "^10.0.10",
		"@types/node": "16.18.101",
		"@types/sinon": "^21.0.1",
		"@types/vscode": "1.71.x",
		"@typescript-eslint/eslint-plugin": "^8.58.0",
		"@typescript-eslint/parser": "^8.58.0",
		"typescript-eslint": "^8.57.1",
		"@vscode/test-electron": "^2.5.2",
		"@vscode/vsce": "^3.7.1",
		"esbuild": "^0.27.4",
		"eslint": "^10.1.0",
		"eslint-config-prettier": "^10.1.8",
		"glob": "^13.0.6",
		"mocha": "^11.7.5",
		"npm-run-all": "^4.1.5",
		"prettier": "^3.8.1",
		"rimraf": "^6.1.3",
		"sinon": "^21.0.3",
		"typescript": "^5.9.3"
	}
}